---
---

<section class="hn-section" data-animate>
  <h2 class="hn-h2">
    <span class="hn-period hn-period--large">.</span>
    <span>Safe by Design</span>
  </h2>
  <p class="hn-sub">Your live site is never touched directly. Every AI action is staged, reviewed, and published on your terms.</p>

  <div class="hn-flow">
    <div class="hn-flow__step">
      <div class="hn-flow__icon">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904 9 18.75l-.813-2.846a4.5 4.5 0 0 0-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 0 0 3.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 0 0 3.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 0 0-3.09 3.09Z" />
        </svg>
      </div>
      <span class="hn-flow__label">AI Assistant</span>
    </div>

    <span class="hn-flow__arrow" aria-hidden="true">&#x2192;</span>

    <div class="hn-flow__step">
      <div class="hn-flow__icon">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M20.25 7.5l-.625 10.632a2.25 2.25 0 01-2.247 2.118H6.622a2.25 2.25 0 01-2.247-2.118L3.75 7.5M10 11.25h4M3.375 7.5h17.25c.621 0 1.125-.504 1.125-1.125v-1.5c0-.621-.504-1.125-1.125-1.125H3.375c-.621 0-1.125.504-1.125 1.125v1.5c0 .621.504 1.125 1.125 1.125z" />
        </svg>
      </div>
      <span class="hn-flow__label">Workspace</span>
    </div>

    <span class="hn-flow__arrow" aria-hidden="true">&#x2192;</span>

    <div class="hn-flow__step">
      <div class="hn-flow__icon">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z" />
        </svg>
      </div>
      <span class="hn-flow__label">Human Review</span>
    </div>

    <span class="hn-flow__arrow" aria-hidden="true">&#x2192;</span>

    <div class="hn-flow__step">
      <div class="hn-flow__icon">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 017.843 4.582M12 3a8.997 8.997 0 00-7.843 4.582m15.686 0A11.953 11.953 0 0112 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0121 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0112 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 013 12c0-1.605.42-3.113 1.157-4.418" />
        </svg>
      </div>
      <span class="hn-flow__label">Live Site</span>
    </div>
  </div>

  <div style="max-width: 680px; margin: 48px auto 0; text-align: center;">
    <p style="font-weight: 300; opacity: .85; font-size: 16px;">
      The AI operates under the authenticated backend user's permissions. All changes are tracked through TYPO3's standard workspace and audit mechanisms. No surprises.
    </p>
  </div>
</section>
