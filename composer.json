{
    "name": "hn/typo3-mcp-server",
    "type": "typo3-cms-extension",
    "description": "TYPO3 extension that provides a Model Context Protocol (MCP) server for interacting with TYPO3 pages and records",
    "license": "GPL-2.0-or-later",
    "homepage": "https://github.com/hauptsacheNet/typo3-mcp-server",
    "authors": [
        {
            "name": "Marco Pfeiffer",
            "email": "marco@hauptsache.net"
        }
    ],
    "require": {
        "php": ">=8.2",
        "logiscape/mcp-sdk-php": "^1.2",
        "typo3/cms-backend": "^13.4",
        "typo3/cms-core": "^13.4",
        "typo3/cms-workspaces": "^13.4"
    },
    "require-dev": {
        "typo3/testing-framework": "^8.2 || ^9.2",
        "typo3/cms-install": "^13.4",
        "typo3/cms-reports": "^13.4",
        "georgringer/news": "^14.0",
        "brianium/paratest": "^7.4"
    },
    "suggest": {
        "typo3/cms-reports": "Enables the GetSystemStatus MCP tool, which surfaces PHP/TYPO3 versions, schema state, security checks and any other status contributed via the Reports API."
    },
    "autoload": {
        "psr-4": {
            "Hn\\McpServer\\": "Classes/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Hn\\McpServer\\Tests\\": "Tests/"
        }
    },
    "extra": {
        "typo3/cms": {
            "extension-key": "mcp_server"
        }
    },
    "scripts": {
        "setup": [
            "bash Build/setup-typo3.sh"
        ],
        "post-install-cmd": [
            "@setup"
        ],
        "post-update-cmd": [
            "@setup"
        ],
        "test": [
            "@test:functional"
        ],
        "test:functional": [
            "paratest -c phpunit.xml.dist"
        ],
        "test:llm": [
            "paratest -c Tests/Llm/phpunit-llm.xml --testdox --no-progress -p 5 --log-junit .Build/llm-results.xml || true",
            "php Build/check-llm-results.php --min-pass=3"
        ],
        "build:ter": "bash Build/build-ter.sh"
    },
    "config": {
        "allow-plugins": {
            "typo3/class-alias-loader": true,
            "typo3/cms-composer-installers": true
        }
    }
}
